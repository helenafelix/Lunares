
<div class="py-2">
    <h2 class="fw-light mb-4">Lista de Salas</h2>


    <table class="table table-hover">
        <thead>
            <tr class="text-secondary small text-uppercase">
                <th>ID</th>
                <th>Nome</th>
                <th>disponibilidade</th>
                <th class="text-end">Capacidade</th>
            </tr>
        </thead>
        <tbody>
            {{#each salas}}
            <tr>
                <td class="text-muted">{{id_sala}}</td>
                <td class="fw-semibold">{{sala}}</td>
                <td>
                    {{#if disponivel}}
                        <span class="text-success">● Disponível</span>
                    {{else}}
                        <span class="text-danger">● Ocupada</span>
                    {{/if}}
                </td>
                <td class="text-end text-muted">{{capasidade}}</td>
            </tr>
            {{/each}}
        </tbody>





    </table>
</div>

