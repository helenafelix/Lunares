<div class="container mt-5">
    <!-- Título com uma linha divisória discreta -->
    <div class="border-bottom pb-3 mb-4">
        <h2 class="h4">Cadastrar Nova Sala</h2>
    </div>

    <!-- Container centralizado para o formulário -->
    <div class="row">
        <div class="col-md-6">
            <form action="/salas/add" method="POST" class="bg-light p-4 rounded shadow-sm">
                
                <div class="mb-3">
                    <label class="form-label">Nome da Sala</label>
                    <input type="text" name="sala" class="form-control" placeholder="Ex: Sala 10" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Capacidade Máxima</label>
                    <input type="number" name="capasidade" class="form-control" placeholder="0" required>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="disponivel" id="disp" checked>
                        <label class="form-check-label" for="disp">Sala Disponível</label>
                    </div>
                </div>

                <!-- Alinhamento dos botões -->
                <div class="d-flex align-items-center">
                    <button type="submit" class="btn btn-primary me-3">Salvar Registro</button>
                    <a href="/salas" class="text-decoration-none text-muted">Cancelar e Voltar</a>
                </div>

            </form>
        </div>
    </div>
</div>
